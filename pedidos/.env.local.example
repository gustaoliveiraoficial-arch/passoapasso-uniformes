# Firebase — copie este arquivo para .env.local e preencha com seus dados
NEXT_PUBLIC_FIREBASE_API_KEY=sua-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Senha do painel administrativo (simples, para uso interno)
NEXT_PUBLIC_ADMIN_PASSWORD=passoapasso2025

# URL base do sistema (para gerar links do cliente)
NEXT_PUBLIC_BASE_URL=http://localhost:3001
