# ============================================
# Synkra AIOS Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOS Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOS_VERSION=2.2.0

# --------------------------------------------
# Meta Ads → Bitrix24 Integration
# --------------------------------------------

# Meta (Facebook/Instagram) Ads
# Token da Página — Facebook → Página → Configurações → Acesso avançado → Tokens
META_PAGE_ACCESS_TOKEN=

# App ID e Secret — developers.facebook.com → Seu App → Configurações → Básico
META_APP_ID=
META_APP_SECRET=

# Token de verificação do webhook (você escolhe, qualquer string segura)
# Deve ser igual ao que você colocar no painel da Meta ao cadastrar o webhook
META_VERIFY_TOKEN=passoapasso_webhook_secret_2026

# ID da Página do Facebook vinculada aos anúncios
META_PAGE_ID=

# Bitrix24 CRM
# Webhook Incoming — Bitrix24 → Aplicativos → Webhooks → Adicionar Webhook Incoming
# Selecione os escopos: CRM (crm), Atividades (log)
# Formato: https://SEU_DOMINIO.bitrix24.com.br/rest/USER_ID/TOKEN/
BITRIX24_WEBHOOK_URL=

# Estágio inicial do negócio no Bitrix24 (veja em CRM → Configurações → Funil de Vendas)
# Padrão 'NEW' funciona para funil padrão. Ex: C1:NEW, C2:PREPAYMENT_INVOICE
BITRIX24_DEAL_STAGE=NEW

# Ticket médio por aluno (usado para calcular valor potencial do negócio)
TICKET_MEDIO_ALUNO=80

# Porta do servidor webhook (Railway define automaticamente via $PORT)
PORT=3001

# --------------------------------------------
# Email — Stories Diários (daily-stories.js)
# --------------------------------------------
# Conta Gmail que ENVIA o email (pode ser a mesma que recebe)
GMAIL_USER=passoapassouniformes2025@gmail.com
# Senha de App do Gmail (não é a senha normal!)
# Gere em: Minha Conta Google → Segurança → Verificação 2 etapas → Senhas de app
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below
